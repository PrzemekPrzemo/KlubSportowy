{
    "name": "przemekprzemo/klubsportowy",
    "description": "Multi-sport, multi-club management portal (PHP 8 + MySQL 8 + Bootstrap 5)",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "mpdf/mpdf": "^8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --colors=always",
        "test:unit": "phpunit --testsuite=Unit --colors=always",
        "lint": "find app -name '*.php' -exec php -l {} \\;"
    },
    "config": {
        "optimize-autoloader": true
    }
}
